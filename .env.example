# Copy to `.env` and adjust.

# --- PostgreSQL (image env + docker-compose publish) ---
POSTGRES_DB=assignment
POSTGRES_USER=assignment
POSTGRES_PASSWORD=password
POSTGRES_PUBLISH_PORT=5433

# --- App: MikroORM / Nest (local: host + published DB port) ---
DB_HOST=localhost
DB_PORT=5433
DB_NAME=assignment
DB_USERNAME=assignment
DB_PASSWORD=password

# Optional URL for tools; runtime uses DB_* (see mikro-orm.config.ts)
DATABASE_URL=postgresql://assignment:password@localhost:5433/assignment

# Local Nest (pnpm start); Docker API overrides PORT inside container
PORT=8080

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PUBLISH_PORT=6379

# Published host port -> container 3000 (Nest in Docker)
API_PUBLISH_PORT=3005
